<?xml version="1.0"?>
<ruleset name="insta-pilot">
    <rule ref="PSR12"/>

    <!-- Лимит длины строки -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="160"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
    <file>app</file>
    <file>database</file>
    <file>tests</file>
    <exclude-pattern>*.blade.php</exclude-pattern>

    <!-- Открывающая скобка класса/метода на той же строке (стиль проекта) -->
    <rule ref="PSR2.Classes.ClassDeclaration.OpenBraceNewLine">
        <exclude name="PSR2.Classes.ClassDeclaration.OpenBraceNewLine"/>
    </rule>
    <rule ref="Squiz.Functions.MultiLineFunctionDeclaration.BraceOnSameLine">
        <exclude name="Squiz.Functions.MultiLineFunctionDeclaration.BraceOnSameLine"/>
    </rule>

    <!-- Пустое тело {} конструктора на одной строке -->
    <rule ref="Squiz.WhiteSpace.ScopeClosingBrace.ContentBefore">
        <exclude name="Squiz.WhiteSpace.ScopeClosingBrace.ContentBefore"/>
    </rule>

    <!-- Разрешить несколько трейтов в одном use-statement -->
    <rule ref="PSR12.Traits.UseDeclaration.MultipleDeclarations">
        <exclude name="PSR12.Traits.UseDeclaration.MultipleDeclarations"/>
    </rule>
    <rule ref="PSR12.Traits.UseDeclaration.MultipleImport">
        <exclude name="PSR12.Traits.UseDeclaration.MultipleImport"/>
    </rule>

    <!-- Разрешить пустую строку в конце control structure (catch, if и др.) -->
    <rule ref="Squiz.WhiteSpace.ControlStructureSpacing.SpacingBeforeClose">
        <exclude name="Squiz.WhiteSpace.ControlStructureSpacing.SpacingBeforeClose"/>
    </rule>

    <!-- PHPUnit требует snake_case в именах тестов (test_foo_bar) -->
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>tests/</exclude-pattern>
    </rule>
</ruleset>
